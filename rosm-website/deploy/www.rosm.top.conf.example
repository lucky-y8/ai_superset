server {
    listen 80;
    listen [::]:80;
    server_name www.rosm.top;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.rosm.top;

    ssl_certificate /etc/letsencrypt/live/www.rosm.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/www.rosm.top/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    root /var/www/rosm;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /robots.txt {
        default_type text/plain;
        try_files $uri =404;
    }

    location = /llms.txt {
        default_type text/plain;
        try_files $uri =404;
    }

    location = /sitemap.xml {
        default_type application/xml;
        try_files $uri =404;
    }

    location ~* \.(css|js|png|jpg|jpeg|webp)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
        try_files $uri =404;
    }
}
