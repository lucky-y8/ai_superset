msgid "X-Axis Sort By"
msgstr "X 轴排序"

#: superset-frontend/packages/superset-ui-chart-controls/src/shared-controls/customControls.tsx:141
msgid "Decides which column or measure to sort the base axis by."
msgstr "决定按哪个度量来对基轴进行排序。"

#: superset-frontend/packages/superset-ui-chart-controls/src/shared-controls/customControls.tsx:204
msgid "Y-Axis Sort Ascending"
msgstr "Y 轴升序排序"

#: superset-frontend/packages/superset-ui-chart-controls/src/shared-controls/customControls.tsx:205
msgid "X-Axis Sort Ascending"
msgstr "X 轴升序排序"

#: superset-frontend/packages/superset-ui-chart-controls/src/shared-controls/customControls.tsx:207
msgid "Whether to sort ascending or descending on the base Axis."
msgstr "确定是按升序还是降序对基轴进行排序。"

