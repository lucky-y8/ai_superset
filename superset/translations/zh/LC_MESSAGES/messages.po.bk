msgstr "次级Y轴标题"

#: superset-frontend/plugins/plugin-chart-echarts/src/MixedTimeseries/controlPanel.tsx:504
msgid "Logarithmic scale on secondary y-axis"
msgstr "二次y轴上的对数刻度"

#: superset-frontend/plugins/plugin-chart-echarts/src/MixedTimeseries/index.ts:61
