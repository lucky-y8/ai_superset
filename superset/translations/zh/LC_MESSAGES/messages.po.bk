msgstr "选择列"

#: superset-frontend/src/components/Datasource/components/DatasourceEditor/DatasourceEditor.tsx:1524
#: superset-frontend/src/components/Datasource/components/DatasourceEditor/DatasourceEditor.tsx:1532
