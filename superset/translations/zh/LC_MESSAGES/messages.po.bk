#: superset-frontend/plugins/plugin-chart-echarts/node_modules/zod/src/v4/core/regexes.ts:46
#, python-brace-format
msgid ""
"{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$/;\n"
"\n"
"/** The classic emailregex.com regex for RFC 5322-compliant emails */\n"
"export const rfc5322Email =\n"
"  /^(([^<>()[]\\.,;:s@\"]+(.[^<>()[]\\.,;:s@\"]+)*)|(\".+\"))@(([[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}])|(([a-zA-Z-0-9]+.)+[a-zA-Z]{2,}))$/;\n"
"\n"
"/** A loose regex that allows Unicode characters, enforces length limits, and that's about it. */\n"
"export const unicodeEmail = /^[^s@\"]{1,64}@[^s@]{1,255}$/u;\n"
"export const idnEmail = unicodeEmail;\n"
"\n"
"export const browserEmail: RegExp =\n"
"  /^[a-zA-Z0-9.!#$%&'*+/=?^_"
msgstr ""
"{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$/;\n"
"\n"
"/** 经典的 emailregex.com 正则表达式，用于符合 RFC 5322 标准的电子邮件 */\n"
"export const rfc5322Email =\n"
"  /^(([^<>()[]\\.,;:s@\"]+(.[^<>()[]\\.,;:s@\"]+)*)|(\".+\"))@(([[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}])|(([a-zA-Z-0-9]+.)+[a-zA-Z]{2,}))$/;\n"
"\n"
"/** 宽松的正则表达式，允许 Unicode 字符，强制长度限制，仅此而已。 */\n"
"export const unicodeEmail = /^[^s@\"]{1,64}@[^s@]{1,255}$/u;\n"
"export const idnEmail = unicodeEmail;\n"
"\n"
"export const browserEmail: RegExp =\n"
"  /^[a-zA-Z0-9.!#$%&'*+/=?^_"

