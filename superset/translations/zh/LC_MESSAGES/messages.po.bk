#: superset/custom_database_errors.py:63
msgid "This is custom error message for a"
msgstr "这是针对 a 的自定义错误消息"

#: superset/custom_database_errors.py:76
msgid "This is custom error message for b"
msgstr "这是 b 的自定义错误消息"

#: superset/errors.py:106
msgid "The datasource is too large to query."
msgstr "数据源太大，无法进行查询。"

#: superset/errors.py:107
msgid "The database is under an unusual load."
msgstr "数据库负载异常。"

#: superset/errors.py:108
msgid "The database returned an unexpected error."
msgstr "数据库返回意外错误。"

#: superset/errors.py:110
msgid ""
"There is a syntax error in the SQL query. Perhaps there was a misspelling or"
" a typo."
msgstr "SQL查询中存在语法错误。可能是拼写错误或是打错关键字。"

#: superset/errors.py:113
msgid "The column was deleted or renamed in the database."
msgstr "该列已在数据库中删除或重命名。"

#: superset/errors.py:114
msgid "The table was deleted or renamed in the database."
msgstr "该表已在数据库中删除或重命名。"

#: superset/errors.py:115
msgid "One or more parameters specified in the query are missing."
msgstr "查询中指定的一个或多个参数丢失。"

#: superset/errors.py:116
msgid "The hostname provided can't be resolved."
msgstr "提供的主机名无法解析。"

#: superset/errors.py:117
msgid "The port is closed."
msgstr "端口已关闭。"

#: superset/errors.py:118
msgid "The host might be down, and can't be reached on the provided port."
msgstr "主机可能已停止，无法在所提供的端口上连接到它"

#: superset/errors.py:119
msgid "Superset encountered an error while running a command."
msgstr "Superset 在执行命令时遇到了一个错误。"

#: superset/errors.py:120
msgid "Superset encountered an unexpected error."
msgstr "Superset 遇到了未知错误。"

#: superset/errors.py:121
msgid "The username provided when connecting to a database is not valid."
msgstr "连接到数据库时提供的用户名无效。"

#: superset/errors.py:122
msgid "The password provided when connecting to a database is not valid."
msgstr "连接数据库时提供的密码无效。"

#: superset/errors.py:123
msgid "Either the username or the password is wrong."
msgstr "用户名或密码错误。"

#: superset/errors.py:124
msgid "Either the database is spelled incorrectly or does not exist."
msgstr "数据库拼写不正确或不存在。"

#: superset/errors.py:125
msgid "The schema was deleted or renamed in the database."
msgstr "该模式已在数据库中删除或重命名。"

#: superset/errors.py:126
msgid "User doesn't have the proper permissions."
msgstr "您没有授权 "

#: superset/errors.py:127
msgid "One or more parameters needed to configure a database are missing."
msgstr "数据库配置缺少所需的一个或多个参数。"

#: superset/errors.py:128
msgid "The submitted payload has the incorrect format."
msgstr "提交的有效载荷格式不正确"

#: superset/errors.py:129
msgid "The submitted payload has the incorrect schema."
msgstr "提交的有效负载的模式不正确。"

#: superset/errors.py:130
msgid "Results backend needed for asynchronous queries is not configured."
msgstr "后端未配置异步查询所需的结果"

#: superset/errors.py:131
msgid "Database does not allow data manipulation."
msgstr "数据库不允许此数据操作。"

#: superset/errors.py:133
msgid ""
"The CTAS (create table as select) doesn't have a SELECT statement at the "
"end. Please make sure your query has a SELECT as its last statement. Then, "
"try running your query again."
msgstr ""
"CTA（create table as "
"select）只能与最后一条语句为SELECT的查询一起运行。请确保查询的最后一个语句是SELECT。然后再次尝试运行查询。"

#: superset/errors.py:137
msgid "CVAS (create view as select) query has more than one statement."
msgstr "CVAS (create view as select)查询有多条语句。"

#: superset/errors.py:138
msgid "CVAS (create view as select) query is not a SELECT statement."
msgstr "CVAS (create view as select)查询不是SELECT语句。"

#: superset/errors.py:139
msgid "Query is too complex and takes too long to run."
msgstr "查询太复杂，运行时间太长。"

#: superset/errors.py:140
msgid "The database is currently running too many queries."
msgstr "数据库当前运行的查询太多"

#: superset/errors.py:141
msgid "One or more parameters specified in the query are malformed."
msgstr "查询中指定的一个或多个参数的格式不正确。"

#: superset/errors.py:142
msgid "The object does not exist in the given database."
msgstr "此数据库中不存在这个对象"

#: superset/errors.py:143
msgid "The query has a syntax error."
msgstr "查询有语法错误。"

#: superset/errors.py:144
msgid "The results backend no longer has the data from the query."
msgstr "结果后端不再拥有来自查询的数据。"

#: superset/errors.py:145
msgid "The query associated with the results was deleted."
msgstr "与结果关联的查询已删除。"

#: superset/errors.py:147
msgid ""
"The results stored in the backend were stored in a different format, and no "
"longer can be deserialized."
msgstr "后端存储的结果以不同的格式存储，而且不再可以反序列化"

#: superset/errors.py:150
msgid "The port number is invalid."
msgstr "端口值无效"

#: superset/errors.py:151 superset/sqllab/sql_json_executer.py:189
msgid "Failed to start remote query on a worker."
msgstr "无法启动远程查询"

#: superset/errors.py:152
msgid "The database was deleted."
msgstr "数据库已删除。"

#: superset/errors.py:153 superset/models/helpers.py:211
msgid "Custom SQL fields cannot contain sub-queries."
msgstr "自定义SQL字段不能包含子查询。"

#: superset/errors.py:154
msgid "The submitted payload failed validation."
msgstr "提交的有效负载的模式不正确。"

#: superset/errors.py:155
msgid "The result size exceeds the allowed limit."
msgstr "结果大小超过了允许的限制。"

#: superset/databases/schemas.py:228 superset/exceptions.py:199
msgid "Invalid certificate"
msgstr "无效认证"

#: superset/exceptions.py:295
msgid "The schema of the submitted payload is invalid."
msgstr "提交的有效载荷模式无效。"

#: superset/exceptions.py:320
msgid "Error parsing"
msgstr "错误（暗色）"

#: superset/exceptions.py:322
#, python-format
msgid " near '%(highlight)s'"
msgstr "在 '%(highlight)s' 附近"

#: superset/exceptions.py:324
#, python-format
msgid " at line %(line)d"
msgstr "在第 %(line)d 行"

#: superset/exceptions.py:480
msgid ""
"This database does not allow for DDL/DML, but the query mutates data. Please"
" contact your administrator for more assistance."
msgstr "找不到此查询中引用的数据库。请与管理员联系以获得进一步帮助，或重试。"

#: superset/exceptions.py:493
msgid ""
"CTAS (create table as select) can only be run with a query where the last "
"statement is a SELECT. Please make sure your query has a SELECT as its last "
"statement. Then, try running your query again."
msgstr ""
"CTA（create table as "
"select）只能与最后一条语句为SELECT的查询一起运行。请确保查询的最后一个语句是SELECT。然后再次尝试运行查询。"

#: superset/exceptions.py:507
msgid ""
"CVAS (create view as select) can only be run with a query with a single "
"SELECT statement. Please make sure your query has only a SELECT statement. "
"Then, try running your query again."
msgstr ""
"CVAS（createview as "
"select）只能与带有单个SELECT语句的查询一起运行。请确保您的查询只有SELECT语句。然后再次尝试运行查询。"

#: superset/commands/sql_lab/results.py:60 superset/exceptions.py:520
msgid "Results backend is not configured."
msgstr "后端未配置结果"

#: superset/jinja_context.py:569
#, python-format
msgid "Unsafe return type for function %(func)s: %(value_type)s"
msgstr "函数返回不安全的类型 %(func)s: %(value_type)s"

#: superset/jinja_context.py:580
#, python-format
msgid "Unsupported return value for method %(name)s"
msgstr "方法的返回值不受支持 %(name)s"

#: superset/jinja_context.py:596
#, python-format
msgid "Unsafe template value for key %(key)s: %(value_type)s"
msgstr "键的模板值不安全 %(key)s: %(value_type)s"

#: superset/jinja_context.py:606
#, python-format
msgid "Unsupported template value for key %(key)s"
msgstr "键的模板值不受支持 %(key)s"

#: superset/jinja_context.py:1089
#, python-format
msgid ""
"Please specify the Dataset ID for the ``%(name)s`` metric in the Jinja "
"macro."
msgstr "请在 Jinja 宏中为 ``%(name)s`` 指标指定数据集 ID。"

#: superset/jinja_context.py:1157
#, python-format
msgid "Metric ``%(metric_name)s`` not found in %(dataset_name)s."
msgstr "在 %(dataset_name)s 中未找到指标 ``%(metric_name)s``。"

#: superset/sql/execution/celery_task.py:452 superset/sql_lab.py:300
#, python-format
msgid ""
"The query was killed after %(sqllab_timeout)s seconds. It might be too "
"complex, or the database might be under heavy load."
msgstr "查询在 %(sqllab_timeout)s 秒后被终止。它可能太复杂，或者数据库可能负载过重。"

#: superset/sql_lab.py:495
#, python-format
msgid "Running block %(block_num)s out of %(block_count)s"
msgstr "正在运行第 %(block_num)s 个块，共 %(block_count)s 个"

#: superset/sql_lab.py:515
#, python-format
msgid "Block %(block_num)s out of %(block_count)s"
msgstr "块 %(block_num)s / %(block_count)s"

#: superset/sql/execution/celery_task.py:275 superset/sql_lab.py:626
msgid "Failed to store query results. Please try again."
msgstr "存储查询结果失败。请重试。"

#: superset/viz.py:125
msgid "Viz is missing a datasource"
msgstr "Viz 缺少一个数据源"

#: superset/viz.py:236
msgid ""
"Applied rolling window did not return any data. Please make sure the source "
"query satisfies the minimum periods defined in the rolling window."
msgstr "应用的滚动窗口（rolling window）未返回任何数据。请确保源查询满足滚动窗口中定义的最小周期。"

#: superset/utils/date_parser.py:644 superset/viz.py:390
msgid "From date cannot be larger than to date"
msgstr "起始日期不能晚于结束日期"

#: superset/viz.py:582
msgid "Cached value not found"
msgstr "缓存的值未找到"

#: superset/viz.py:598
#, python-format
msgid "Columns missing in datasource: %(invalid_columns)s"
msgstr "数据源中缺少列：%(invalid_columns)s"

#: superset/viz.py:735
msgid "Time Table View"
msgstr "时间表视图"

#: superset/viz.py:744
msgid "Pick at least one metric"
msgstr "选择至少一个指标"

#: superset/viz.py:748
msgid "When using 'Group By' you are limited to use a single metric"
msgstr "当使用“Group by”时，只限于使用单个度量。"

#: superset-frontend/plugins/legacy-plugin-chart-calendar/src/index.ts:35
#: superset/viz.py:786
msgid "Calendar Heatmap"
msgstr "时间热力图"

#: superset-frontend/plugins/plugin-chart-echarts/src/Bubble/index.ts:52
#: superset/viz.py:875
msgid "Bubble Chart"
msgstr "气泡图"

#: superset/viz.py:898
msgid "Please use 3 different metric labels"
msgstr "请在左右轴上选择不同的指标"

#: superset/viz.py:900
msgid "Pick a metric for x, y and size"
msgstr "为 x 轴，y 轴和大小选择一个指标"

#: superset-frontend/plugins/legacy-preset-chart-nvd3/src/Bullet/index.ts:35
#: superset/viz.py:927
msgid "Bullet Chart"
msgstr "子弹图"

#: superset/viz.py:940
msgid "Pick a metric to display"
msgstr "选择一个指标来显示"

#: superset/viz.py:958
msgid "Time Series - Line Chart"
msgstr "时间序列-折线图"

#: superset/models/helpers.py:1390 superset/viz.py:1097
msgid ""
"An enclosed time range (both start and end) must be specified when using a "
"Time Comparison."
msgstr "使用时间比较时，必须指定封闭的时间范围（有开始和结束）。"

#: superset/viz.py:1164
msgid "Time Series - Period Pivot"
msgstr "时间序列 - 周期透视表"

#: superset/viz.py:1211
msgid "Time Series - Percent Change"
msgstr "时间序列 - 百分比变化"

#: superset/viz.py:1218
msgid "Directed Force Layout"
msgstr "有向力导向布局"

#: superset-frontend/plugins/legacy-plugin-chart-country-map/src/index.ts:40
#: superset/viz.py:1258
msgid "Country Map"
msgstr "国家地图"

#: superset-frontend/plugins/legacy-plugin-chart-world-map/src/index.ts:40
#: superset/viz.py:1294
msgid "World Map"
msgstr "世界地图"

#: superset-frontend/plugins/legacy-plugin-chart-parallel-coordinates/src/index.ts:40
#: superset/viz.py:1362
msgid "Parallel Coordinates"
msgstr "平行坐标"

#: superset/viz.py:1395
msgid "Horizon Charts"
msgstr "水平图表"

#: superset/viz.py:1405
msgid "Mapbox"
msgstr "MapBox地图"

#: superset/viz.py:1420
msgid "[Longitude] and [Latitude] must be set"
msgstr "[经度] 和 [纬度] 的必须设置"

#: superset/viz.py:1431
msgid "Must have a [Group By] column to have 'count' as the [Label]"
msgstr "[Group By] 列必须要有 ‘count’字段作为 [标签]"

#: superset/viz.py:1454
msgid "Choice of [Label] must be present in [Group By]"
msgstr "[标签] 的选择项必须出现在 [Group By]"

#: superset/viz.py:1462
msgid "Choice of [Point Radius] must be present in [Group By]"
msgstr "[点半径] 的选择项必须出现在 [Group By]"

#: superset/viz.py:1471
msgid "[Longitude] and [Latitude] columns must be present in [Group By]"
msgstr "[经度] 和 [纬度] 的选择项必须出现在 [Group By]"

#: superset-frontend/plugins/plugin-chart-point-cluster-map/src/index.ts:37
#: superset/viz.py:1553
msgid "Point Cluster Map"
msgstr "点簇地图"

#: superset/viz.py:1576
msgid "Deck.gl - Multiple Layers"
msgstr "Deck.gl - 多图层"

#: superset/viz.py:1853 superset/viz.py:1893
msgid "Bad spatial key"
msgstr "错误的空间字段"

#: superset/viz.py:1875
msgid "Invalid spatial point encountered: %(latlong)s"
msgstr "遇到无效的空间点：%(latlong)s"

#: superset/viz.py:1917
msgid ""
"Encountered invalid NULL spatial entry,"
"                                        please consider filtering those out"
msgstr "遇到无效的为 NULL 的空间条目，请考虑将其过滤掉"

#: superset/viz.py:2013
msgid "Deck.gl - Scatter plot"
msgstr "Deck.gl - 散点图"

#: superset/viz.py:2072
msgid "Deck.gl - Screen Grid"
msgstr "Deck.gl - 屏幕网格"

#: superset/viz.py:2151
msgid "Deck.gl - 3D Grid"
msgstr "Deck.gl - 3D网格"

#: superset/viz.py:2206
msgid "Deck.gl - Paths"
msgstr "Deck.gl - 路径"

#: superset/viz.py:2285
msgid "Deck.gl - Polygon"
msgstr "Deck.gl - 多边形"

#: superset/viz.py:2350
msgid "Deck.gl - 3D HEX"
msgstr "Deck.gl - 3D六角曲面"

#: superset/viz.py:2385
msgid "Deck.gl - Heatmap"
msgstr "Deck.gl - 热力图"

#: superset/viz.py:2420
msgid "Deck.gl - Contour"
msgstr "Deck.gl - 等高线"

#: superset/viz.py:2460
msgid "Deck.gl - GeoJSON"
msgstr "Deck.gl - GeoJSON"

#: superset/viz.py:2480
msgid "Deck.gl - Arc"
msgstr "Deck.gl - 弧度"

#: superset/viz.py:2550
msgid "Event flow"
msgstr "事件流"

#: superset/viz.py:2583
msgid "Time Series - Paired t-test"
msgstr "时间序列 - 配对t检验"

#: superset/viz.py:2655
msgid "Time Series - Nightingale Rose Chart"
msgstr "时间序列 - 南丁格尔玫瑰图"

#: superset/viz.py:2690
msgid "Partition Diagram"
msgstr "分区图"

#: superset/viz.py:2861
msgid "Please choose at least one groupby"
msgstr "请至少选择一个分组字段 "

#: superset/advanced_data_type/api.py:107
msgid "Invalid advanced data type: %(advanced_data_type)s"
msgstr "无效的高级数据类型：%(advanced_data_type)s"

#: superset/annotation_layers/api.py:350
#, python-format
msgid "Deleted %(num)d annotation layer"
msgid_plural "Deleted %(num)d annotation layers"
msgstr[0] "删除了 %(num)d 个注释层"

#: superset/annotation_layers/annotations/filters.py:28
#: superset/annotation_layers/filters.py:28 superset/charts/filters.py:37
#: superset/css_templates/filters.py:28
#: superset/queries/saved_queries/filters.py:32 superset/reports/filters.py:44
#: superset/themes/filters.py:28
msgid "All Text"
msgstr "所有文本"

#: superset/annotation_layers/annotations/api.py:492
#, python-format
msgid "Deleted %(num)d annotation"
msgid_plural "Deleted %(num)d annotations"
msgstr[0] "删除了 %(num)d 个注释"

#: superset/charts/api.py:561
#, python-format
msgid "Deleted %(num)d chart"
msgid_plural "Deleted %(num)d charts"
msgstr[0] "删除了 %(num)d 个图表"

#: superset/charts/client_processing.py:77
#, python-format
msgid "Total (%(aggfunc)s)"
msgstr "总计 (%(aggfunc)s)"

#: superset-frontend/plugins/plugin-chart-pivot-table/src/react-pivottable/TableRenderers.tsx:1076
#: superset-frontend/plugins/plugin-chart-pivot-table/src/react-pivottable/TableRenderers.tsx:1336
#: superset/charts/client_processing.py:178
#: superset/charts/client_processing.py:204
msgid "Subtotal"
msgstr "小计"

#: superset/charts/filters.py:91 superset/dashboards/filters.py:223
#: superset/datasets/filters.py:39
msgid "Is certified"
msgstr "已认证"

#: superset/charts/filters.py:120 superset/dashboards/filters.py:249
msgid "Has created by"
msgstr "已创建"

#: superset/charts/filters.py:132 superset/dashboards/filters.py:56
msgid "Created by me"
msgstr "我创建的"

#: superset/charts/filters.py:152
msgid "Owned Created or Favored"
msgstr "已拥有、已创建或已收藏"

#: superset/charts/schemas.py:674
msgid "`confidence_interval` must be between 0 and 1 (exclusive)"
msgstr "`置信区间` 必须介于0和1之间（开区间）"

#: superset/charts/schemas.py:756
msgid ""
"lower percentile must be greater than 0 and less than 100. Must be lower "
"than upper percentile."
msgstr "下百分位数必须大于0且小于100。而且必须低于上百分位"

#: superset/charts/schemas.py:771
msgid ""
"upper percentile must be greater than 0 and less than 100. Must be higher "
"than lower percentile."
msgstr "上百分位数必须大于0且小于100。而且必须高于下百分位。"

#: superset/charts/schemas.py:1141
msgid "`width` must be greater or equal to 0"
msgstr "`宽度` 必须大于或等于0"

#: superset/charts/schemas.py:1323
msgid "`row_limit` must be greater than or equal to 0"
msgstr "`行限制` 必须大于或等于0"

#: superset/charts/schemas.py:1330
msgid "`row_offset` must be greater than or equal to 0"
msgstr "`行偏移量` 必须大于或等于0"

#: superset/charts/schemas.py:1352
msgid "orderby column must be populated"
msgstr "必须填充用于排序的列"

#: superset/charts/data/api.py:172
msgid "Chart has no query context saved. Please save the chart again."
msgstr "图表未保存任何查询上下文。请重新保存图表。"

#: superset/charts/data/api.py:255 superset/charts/data/api.py:355
#: superset/charts/data/api.py:438
#, python-format
msgid "Request is incorrect: %(error)s"
msgstr "请求不正确: %(error)s"

#: superset/charts/data/api.py:342
msgid "Request is not JSON"
msgstr "请求不是JSON"

#: superset/charts/data/api.py:506
msgid "Empty query result"
msgstr "空的查询结果"

#: superset/charts/data/dashboard_filter_context.py:226
#, python-format
msgid "Chart %(chart_id)s is not on dashboard %(dashboard_id)s"
msgstr "图表 %(chart_id)s 不在仪表盘 %(dashboard_id)s 上"

#: superset/charts/data/dashboard_filter_context.py:264
#, python-format
msgid "Dashboard %(dashboard_id)s not found"
msgstr "仪表盘 %(dashboard_id)s 未找到"

#: superset/commands/dataset/exceptions.py:146
#: superset/commands/exceptions.py:112
msgid "Owners are invalid"
msgstr "所有者无效"

#: superset/commands/exceptions.py:119
msgid "Some roles do not exist"
msgstr "看板"

#: superset/commands/exceptions.py:127
msgid "Datasource type is invalid"
msgstr "数据源类型无效"

#: superset/commands/exceptions.py:135
msgid "Datasource does not exist"
msgstr "数据集不存在"

#: superset/commands/exceptions.py:142
msgid "Query does not exist"
msgstr "查询不存在"

#: superset/commands/annotation_layer/exceptions.py:29
msgid "Annotation layer parameters are invalid."
msgstr "注释层仍在加载。"

#: superset/commands/annotation_layer/exceptions.py:33
msgid "Annotation layer could not be created."
msgstr "无法创建注释层"

#: superset/commands/annotation_layer/exceptions.py:37
msgid "Annotation layer could not be updated."
msgstr "无法更新注释层"

