msgstr "无效的经度/纬度"

#: superset/utils/pandas_postprocessing/geography.py:120
msgid "Invalid geodetic string"
msgstr "无效的 geodetic 字符串"

#: superset/utils/pandas_postprocessing/pivot.py:119
